    "react-test": "react-app-rewired test",
    "style:inventory": "node scripts/style-inventory.js",
    "style:trace": "node scripts/style-trace.js",
    "style:lint": "stylelint \"src/**/*.css\"",
    "style:migrate-primitives": "node scripts/migrate-primitives.js",
    "style:canonicalize-tokens": "node scripts/canonicalize-theme-tokens.js",
    "style:extract-chat-graphql": "node scripts/extract-chat-graphql.js",
    "style:extract-chat-messages": "node scripts/extract-chat-messages.js",
    "style:migrate-layouts": "node scripts/migrate-layout-contracts.js",
